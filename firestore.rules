rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'panupongs@nu.ac.th';
    }
    
    // Helper function to check if user is teacher
    function isTeacher() {
      return request.auth != null && (
        isAdmin() ||
        exists(/databases/$(database)/documents/allowed_teachers/$(request.auth.token.email))
      );
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allowed Teachers (admin only)
    match /allowed_teachers/{email} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Pending Students (for pre-registration)
    match /pending_students/{email} {
      allow read: if request.auth != null;
      allow write: if isTeacher() || isAdmin();
    }
    
    // Classrooms collection - use teacherIds array
    match /classrooms/{classroomId} {
      allow read: if request.auth != null;
      allow create: if isTeacher();
      allow update, delete: if request.auth != null && (
        request.auth.uid in resource.data.teacherIds || isAdmin()
      );
    }
    
    // Students collection
    match /students/{studentId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isTeacher();
    }
    
    // Sessions collection
    match /sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create, update: if isTeacher();
      allow delete: if isAdmin();
    }
    
    // Attendance collection
    match /attendance/{attendanceId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if isAdmin();
    }
    
    // Grade Categories collection
    match /grades_categories/{categoryId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isTeacher();
    }
    
    // Grades collection
    match /grades/{gradeId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isTeacher();
    }
    
    // Config collection (admin only for write)
    match /config/{configId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Exit Tickets collection
    match /exit_tickets/{ticketId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }
  }
}
